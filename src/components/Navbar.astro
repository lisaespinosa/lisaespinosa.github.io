---
import { siteContent } from "../data/siteContent";
---
<nav class="fixed top-0 w-full z-50 bg-stone-950/70 backdrop-blur-xl border-b border-white/5 surface-container-low">
  <div class="flex justify-between items-center px-8 py-6 max-w-screen-2xl mx-auto">
    <div class="text-2xl font-serif italic text-orange-200">
      {siteContent.navbar.brandName}
    </div>
    <div class="hidden md:flex items-center space-x-8 font-serif text-lg tracking-tight noto-serif">
      {siteContent.navbar.links.map((link) => (
        <a class="text-stone-400 hover:text-orange-100 transition-colors duration-300" href={link.href}>
          {link.label}
        </a>
      ))}
    </div>
    <a href="#contact" class="bg-primary text-on-primary px-6 py-2.5 rounded-full font-medium scale-95 duration-200 ease-in-out hover:brightness-110 inline-block text-center">
      {siteContent.navbar.ctaText}
    </a>
  </div>
</nav>
