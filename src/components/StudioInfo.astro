---
import { Image } from "astro:assets";
import studioBeach from "../assets/studio_beach.jpg";
import { siteContent } from "../data/siteContent";
---
<section class="py-24 bg-surface">
  <div class="container mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-2 bg-surface-container-low p-12 rounded-xl border border-outline-variant/10">
        <h2 class="text-3xl noto-serif mb-8 text-on-background">{siteContent.studioInfo.audience.title}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div class="space-y-4">
            {siteContent.studioInfo.audience.categories.slice(0, 2).map((cat) => (
              <div class="p-4 bg-surface rounded-lg">
                <p class="font-bold text-primary mb-1">{cat.title}</p>
                <p class="text-sm text-on-surface-variant">{cat.description}</p>
              </div>
            ))}
          </div>
          <div class="space-y-4">
            {siteContent.studioInfo.audience.categories.slice(2).map((cat) => (
              <div class="p-4 bg-surface rounded-lg">
                <p class="font-bold text-primary mb-1">{cat.title}</p>
                <p class="text-sm text-on-surface-variant">{cat.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="bg-primary-container p-12 rounded-xl flex flex-col justify-between overflow-hidden relative">
        <div class="relative z-10">
          <h2 class="text-3xl noto-serif mb-6 text-primary">{siteContent.studioInfo.environment.title}</h2>
          <p class="text-on-primary-container leading-relaxed mb-8">
            {siteContent.studioInfo.environment.description}
          </p>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">location_on</span>
            <span class="text-sm font-medium">{siteContent.studioInfo.environment.location}</span>
          </div>
        </div>
        <div class="absolute -right-4 -bottom-4 w-48 h-48 opacity-20 transform rotate-12">
          <Image src={studioBeach} alt="Cello at the beach" class="w-full h-full object-cover rounded-xl" />
        </div>
      </div>
    </div>
  </div>
</section>
