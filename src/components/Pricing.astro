---
import { siteContent } from "../data/siteContent";
---
<section class="py-24 bg-surface" id="pricing">
  <div class="container mx-auto px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl noto-serif font-bold mb-4">{siteContent.pricing.title}</h2>
      <p class="text-on-surface-variant max-w-2xl mx-auto">{siteContent.pricing.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {siteContent.pricing.tiers.map((tier) => (
        <div class="bg-surface-container-high p-10 rounded-xl flex flex-col items-center text-center transition-transform hover:-translate-y-2">
          <h3 class="text-2xl font-bold mb-2">
            {tier.duration}
          </h3>
          <div class="text-4xl noto-serif text-primary mb-6">
            {tier.price}
            <span class="text-sm text-on-surface-variant font-sans">
              {tier.unit}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
