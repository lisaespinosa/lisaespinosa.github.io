---
import { Image } from "astro:assets";
import headshot from "../assets/headshot.jpg";
import { siteContent } from "../data/siteContent";
---
<section class="py-24 bg-surface-container-low" id="background">
  <div class="container mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-5">
        <div class="relative">
          <div class="aspect-square rounded-2xl overflow-hidden shadow-2xl border-4 border-surface-container-high">
            <Image src={headshot} alt="Instructor Headshot" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -bottom-6 -right-6 bg-primary p-6 rounded-xl shadow-xl hidden md:block">
            <span class="material-symbols-outlined text-on-primary text-4xl">music_note</span>
          </div>
        </div>
      </div>
      <div class="lg:col-span-7">
        <div class="mb-10 text-left">
          <span class="text-tertiary uppercase tracking-widest text-xs font-bold mb-4 block">{siteContent.credentials.badge}</span>
          <h2 class="text-4xl md:text-5xl noto-serif font-bold mb-6">{siteContent.credentials.title}</h2>
          <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
            {siteContent.credentials.description}
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {siteContent.credentials.highlights.map((highlight) => (
            <div class="flex items-center gap-4 p-5 bg-surface-container-lowest rounded-xl border border-outline-variant/10">
              <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">{highlight.icon}</span>
              <p class="font-medium">{highlight.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
