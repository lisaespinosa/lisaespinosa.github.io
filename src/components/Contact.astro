---
import { siteContent } from "../data/siteContent";
---
<section class="py-24 bg-surface-container-lowest" id="contact">
  <div class="container mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div>
        <h2 class="text-4xl md:text-5xl noto-serif font-bold mb-8">{siteContent.contact.title}</h2>
        <p class="text-lg text-on-surface-variant mb-10 leading-relaxed">
          {siteContent.contact.description}
        </p>
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
              <span class="material-symbols-outlined text-primary">distance</span>
            </div>
            <div>
              <p class="text-sm text-on-surface-variant">Location</p>
              <p class="font-medium">{siteContent.contact.details.location}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-surface-container-low p-8 md:p-12 rounded-2xl">
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">{siteContent.contact.form.nameLabel}</label>
              <input class="w-full bg-surface border-none focus:ring-2 focus:ring-primary rounded-lg p-4 text-on-background" placeholder={siteContent.contact.form.namePlaceholder} type="text" required />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">{siteContent.contact.form.emailLabel}</label>
              <input class="w-full bg-surface border-none focus:ring-2 focus:ring-primary rounded-lg p-4 text-on-background" placeholder={siteContent.contact.form.emailPlaceholder} type="email" required />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">{siteContent.contact.form.ageLabel}</label>
            <input class="w-full bg-surface border-none focus:ring-2 focus:ring-primary rounded-lg p-4 text-on-background" placeholder={siteContent.contact.form.agePlaceholder} type="text" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">{siteContent.contact.form.messageLabel}</label>
            <textarea class="w-full bg-surface border-none focus:ring-2 focus:ring-primary rounded-lg p-4 text-on-background" placeholder={siteContent.contact.form.messagePlaceholder} rows="4" required></textarea>
          </div>
          <button class="w-full bg-primary text-on-primary py-4 rounded-full font-bold text-lg hover:brightness-110 transition-all shadow-lg" type="submit">
            {siteContent.contact.form.submitButtonText}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
