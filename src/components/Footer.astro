---
import { siteContent } from "../data/siteContent";
---
<footer class="bg-stone-950 w-full py-16 px-8 border-t border-stone-800/20 surface-container-lowest">
  <div class="flex flex-col md:flex-row justify-between items-center gap-8 max-w-7xl mx-auto">
    <div class="text-lg font-serif text-orange-200">
      {siteContent.footer.brandName}
    </div>

    <div class="text-stone-500 font-sans text-xs tracking-widest inter text-center md:text-right">
      © {new Date().getFullYear()} {siteContent.footer.copyrightSuffix}
    </div>
  </div>
</footer>
